# ================================================
# Saturday Nights Billiard - Backend Environment
# Copy this file to .env and fill in your values
# ================================================

# Database (Supabase PostgreSQL)
# Get from: https://supabase.com > Project Settings > Database > Connection String
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# JWT Secrets (generate random strings - use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="REPLACE_WITH_RANDOM_64_CHAR_STRING"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:8081"

# PayMongo (Online Payments - Free to integrate, get from paymongo.com)
PAYMONGO_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_KEY"
PAYMONGO_PUBLIC_KEY="pk_test_REPLACE_WITH_YOUR_KEY"

# Supabase (for real-time & storage)
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="REPLACE_WITH_YOUR_ANON_KEY"
SUPABASE_SERVICE_KEY="REPLACE_WITH_YOUR_SERVICE_KEY"

# Email Notifications (Gmail SMTP - Free)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-billiard-hall-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# Sensor API Key (secret between Raspberry Pi and backend)
SENSOR_API_KEY="REPLACE_WITH_RANDOM_KEY_FOR_RASPBERRY_PI"

# Loyalty Settings
HOURS_FOR_FREE_HOUR=20          # Play 20 hours = earn 1 free hour (60 credits)
BIRTHDAY_FREE_CREDITS=60        # 1 free hour on birthday
LOW_CREDIT_THRESHOLD=30         # Alert when below 30 credits (30 minutes)
